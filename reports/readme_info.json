{
  "project_name": "cycpep-tools",
  "description": "MCP tools for cyclic peptide computational analysis - Generate molecular images, predict membrane permeability, and analyze feature fusion methods using MultiCycPermea",
  "server_info": {
    "name": "cycpep-tools",
    "version": "1.0.0",
    "total_tools": 14,
    "server_path": "src/server.py"
  },
  "tools": [
    {
      "name": "generate_peptide_images",
      "type": "sync",
      "category": "molecular_visualization",
      "description": "Generate 2D molecular structure images for cyclic peptides from SMILES",
      "runtime": "~1.3s for 5 peptides",
      "example_prompt": "Generate molecular images for @examples/data/sequences/test_small.csv",
      "parameters": ["input_file", "output_dir", "image_size", "image_format", "use_coord_gen"]
    },
    {
      "name": "analyze_peptide_features",
      "type": "sync",
      "category": "feature_analysis",
      "description": "Analyze and compare feature combination methods for cyclic peptides",
      "runtime": "~3.4s for 5 peptides",
      "example_prompt": "Analyze feature fusion methods for @examples/data/sequences/test_small.csv",
      "parameters": ["input_file", "output_dir", "methods", "random_seed", "plot_dpi"]
    },
    {
      "name": "validate_peptide_csv",
      "type": "sync",
      "category": "data_validation",
      "description": "Validate CSV format and SMILES validity for cyclic peptides",
      "runtime": "<1s",
      "example_prompt": "Validate the CSV file at @examples/data/sequences/test.csv",
      "parameters": ["input_file", "required_columns"]
    },
    {
      "name": "submit_batch_image_generation",
      "type": "async",
      "category": "batch_processing",
      "description": "Submit large-scale image generation for background processing",
      "runtime": "background job",
      "example_prompt": "Submit batch image generation for @examples/data/sequences/test.csv",
      "parameters": ["input_file", "output_dir", "image_size", "image_format", "job_name"]
    },
    {
      "name": "submit_batch_feature_analysis",
      "type": "async",
      "category": "batch_processing",
      "description": "Submit comprehensive feature analysis for background processing",
      "runtime": "background job",
      "example_prompt": "Submit batch feature analysis for @examples/data/sequences/test.csv",
      "parameters": ["input_file", "output_dir", "methods", "random_seed", "job_name"]
    },
    {
      "name": "get_job_status",
      "type": "job_management",
      "category": "job_control",
      "description": "Check job progress and status",
      "runtime": "immediate",
      "example_prompt": "Check the status of job abc12345"
    },
    {
      "name": "get_job_result",
      "type": "job_management",
      "category": "job_control",
      "description": "Get results when job completed",
      "runtime": "immediate",
      "example_prompt": "Get the results of job abc12345"
    },
    {
      "name": "get_job_log",
      "type": "job_management",
      "category": "job_control",
      "description": "View execution logs from jobs",
      "runtime": "immediate",
      "example_prompt": "Show me the log for job abc12345"
    },
    {
      "name": "cancel_job",
      "type": "job_management",
      "category": "job_control",
      "description": "Cancel running job",
      "runtime": "immediate",
      "example_prompt": "Cancel job abc12345"
    },
    {
      "name": "list_jobs",
      "type": "job_management",
      "category": "job_control",
      "description": "List all jobs with filters",
      "runtime": "immediate",
      "example_prompt": "List all my recent jobs"
    },
    {
      "name": "cleanup_old_jobs",
      "type": "job_management",
      "category": "job_control",
      "description": "Remove old completed jobs",
      "runtime": "immediate",
      "example_prompt": "Clean up old jobs older than 30 days"
    },
    {
      "name": "get_server_info",
      "type": "utility",
      "category": "server_info",
      "description": "Get server status and tool information",
      "runtime": "immediate",
      "example_prompt": "What tools are available from cycpep-tools?"
    },
    {
      "name": "get_example_data_info",
      "type": "utility",
      "category": "data_info",
      "description": "List available datasets with statistics",
      "runtime": "immediate",
      "example_prompt": "Show me information about available example datasets"
    },
    {
      "name": "load_config_template",
      "type": "utility",
      "category": "configuration",
      "description": "Load configuration templates",
      "runtime": "immediate",
      "example_prompt": "Load the configuration template for draw_peptide_images"
    }
  ],
  "scripts": [
    {
      "name": "draw_peptide_images.py",
      "path": "scripts/draw_peptide_images.py",
      "description": "Generate 2D molecular structure images for cyclic peptides",
      "example_command": "python scripts/draw_peptide_images.py --input examples/data/sequences/test_small.csv --output results/images",
      "runtime": "~1.3s for 5 peptides",
      "independence": "fully independent"
    },
    {
      "name": "feature_analysis.py",
      "path": "scripts/feature_analysis.py",
      "description": "Analyze and compare feature fusion methods for cyclic peptides",
      "example_command": "python scripts/feature_analysis.py --input examples/data/sequences/test_small.csv --methods concate,cross_attention",
      "runtime": "~3.4s for 5 peptides",
      "independence": "fully independent"
    }
  ],
